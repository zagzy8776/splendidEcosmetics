# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# URL of the deployed backend API (no trailing slash)
VITE_API_URL=https://your-backend.onrender.com

# ─── Backend (server.js) ──────────────────────────────────────────────────────
# PostgreSQL connection string (e.g. from Neon, Supabase, Railway)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Admin password — set a strong unique value, never commit the real value
ADMIN_PASSWORD=change-me-to-something-strong

# Port the backend listens on (Render sets this automatically)
PORT=4000

# Allowed frontend origin for CORS (your Vercel deployment URL)
FRONTEND_URL=https://your-frontend.vercel.app
